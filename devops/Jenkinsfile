/*
  Practica 2 - Jenkinsfile  Pipelines CI/CD en Jenkins con Docker y Groovy 
*/

pipeline {
  // `agent any` = el pipeline se ejecuta en cualquier nodo/agente disponible.
  agent any

  stages {
    stage('Info') {
      steps {
        // TODO (E1): imprime JOB_NAME y BUILD_NUMBER
        echo "Job: ${env.JOB_NAME}"
        echo "Build: ${env.BUILD_NUMBER}"
      }
    }


    // =========================
    // Ejercicio 3 (preparación): construir imagen CI con make
    // =========================
    stage('CI - Build tools image') {
      steps {
        script {
          // TODO (E3): Construye una imagen de CI desde devops/ci.Dockerfile.
          env.CI_IMAGE_NAME = "python-ci-tools:${env.BUILD_NUMBER}"
          docker.build(env.CI_IMAGE_NAME, "-f devops/ci.Dockerfile .")
        }
      }
    }

    // =========================
    // Ejercicio 3 (separar CI): stage Lint
    // =========================
    stage('CI - Lint') {
      agent {
        docker {
          image 'python:3.6-slim'
        }
      }
      steps {
        script {
          // TODO (E3): Ejecuta lint en contenedor Python.
          sh 'pip install -r requirements.txt flake8 mypy'
          docker.image(image).inside { sh 'make lint' }
          //sh 'make lint'
        }
      }
    }


    // =========================
    // Ejercicio 2 (Docker como agente) 
    // =========================
    stage('Test') {
      steps {
        script {
          // TODO (E2): Ejecuta los tests unitarios dentro de la imagen CI construida.
          sh 'pip install -r requirements.txt'
          sh 'pytest -q'
        }
      }
    }

   
  }
}
