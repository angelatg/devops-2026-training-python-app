/*
  Practica 2 - Jenkinsfile  Pipelines CI/CD en Jenkins con Docker y Groovy 
*/

// =========================
// Ejercicio 4 (Groovy): función reutilizable
// =========================
def runInDocker(String image, Closure body) {
  // TODO (E4): Ejecuta `body()` dentro del contenedor indicado usando Docker Pipeline:
  docker.image(image).inside { body() }
}


pipeline {
  // `agent any` = el pipeline se ejecuta en cualquier nodo/agente disponible.
  agent any

  parameters {
    // [E6.1] TODO: añade parámetro para habilitar CD.
    booleanParam(name: 'RUN_CD', defaultValue: false, description: 'Ejecutar CD')
  }

  environment {
    // [E6.4] TODO: define variables compartidas del pipeline.
    IMAGE_NAME = 'angelatg/devops-training-python-app:0.0.1'
    CI_IMAGE_NAME = "python-ci-tools:${env.BUILD_NUMBER}"
    CD_LOCAL_NAME = "localapp"

  }


  stages {
    stage('Info') {
      steps {
        // TODO (E1): imprime JOB_NAME y BUILD_NUMBER
        echo "Job: ${env.JOB_NAME}"
        echo "Build: ${env.BUILD_NUMBER}"
      }
    }


    // =========================
    // Ejercicio 3 (preparación): construir imagen CI con make
    // =========================
    stage('CI - Build tools image') {
      steps {
        script {
          // TODO (E3): Construye una imagen de CI desde devops/ci.Dockerfile.
          docker.build(env.CI_IMAGE_NAME, "-f devops/ci.Dockerfile .")
        }
      }
    }

    // =========================
    // Ejercicio 3 (separar CI): stage Lint
    // =========================
    stage('CI - Lint') {
      steps {
        script {
          // TODO (E3/E4): Ejecuta lint en contenedor Python.
          runInDocker(env.CI_IMAGE_NAME) {
            sh 'pip install -r requirements.txt flake8 mypy'
            sh 'make lint'
          }
        }
      }
    }


    // =========================
    // Ejercicio 2 (Docker como agente) + Ejercicio 4 (refactor con runInDocker)
    // =========================
    stage('Test') {
        steps {
        script {
          // TODO (E2/E4): Ejecuta los tests unitarios dentro de la imagen CI construida.
          runInDocker(env.CI_IMAGE_NAME) {
            sh 'python --version'
            sh 'pip install -r requirements.txt'
            sh 'pytest -q'
          }
        }
      }
    }


    // =========================
    // Ejercicio 5 (docker build)
    // =========================
    stage('CI - Build image') {
      steps {
        script {
          // TODO (E5): Construye la imagen Docker usando el Dockerfile del repo:
          docker.build(env.IMAGE_NAME, "-f devops/Dockerfile .")
        }
      }
    }

    
    // =========================
    // Ejercicio 6 (compose) + Ejercicio 6.1 (solo develop/master)
    // =========================
    stage('CD') {
      when {
        allOf {
          anyOf {
            // [E6.1] TODO: añade parámetro para habilitar CD.
            expression { return params.RUN_CD }
            branch 'develop'
            branch 'master'
          }
        }
      }
      steps {
        echo "CD habilitado: RUN_CD=${params.RUN_CD}, branch=${env.BRANCH_NAME}"
        script {
          // [E6.2] TODO: calcular DEPLOY_ENV y COMPOSE_PROJECT.
          env.DEPLOY_ENV = (env.BRANCH_NAME == 'master') ? 'PRO' : 'DEV'
          env.COMPOSE_PROJECT = env.DEPLOY_ENV.toLowerCase()

          // TODO (E6/E6.2): Ejecuta:
          sh "docker compose -p ${env.COMPOSE_PROJECT} up -d"
          sh "sleep 5 && docker compose -p ${env.COMPOSE_PROJECT} logs app"
          
        }
      }
      post {
        always {
          // TODO (E6)
          sh "docker compose -p ${env.COMPOSE_PROJECT} down --volumes"
        }
      }

    }
  }

  post {
      always {
          // Limpieza: esto debe ejecutarse tanto si falla como si va bien.
         sh 'docker compose down --volumes || true'
         sh 'docker rmi IMAGE_NAME || true'
      }
      success {
          echo 'SUCCESS'
      }
      failure {
          echo 'FAILURE'
           sh 'docker compose logs || true'
      }
  }
}
